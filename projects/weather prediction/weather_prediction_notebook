    "df['Date'] = pd.to_datetime(df['Date'], format='mixed', dayfirst=True)\n",
    "df['Year'] = df['Date'].dt.year\n",
    "\n",
    "# Fix Cloud9am and Cloud3pm — value 9 is invalid (oktas range is 0–8)\n",
    "print(\"Cloud9am value counts BEFORE correction:\")\n",
